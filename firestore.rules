rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Tutors collection
    match /tutors/{tutorId} {
      allow get: if isOwner(tutorId);
      allow create: if isOwner(tutorId) 
        && incoming().uid == request.auth.uid
        && incoming().email is string;
      allow update: if isOwner(tutorId) 
        && incoming().uid == existing().uid;
    }

    // Students collection
    match /students/{studentId} {
      allow list: if isSignedIn() && resource.data.tutorId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.tutorId == request.auth.uid;
      allow create: if isSignedIn() 
        && incoming().tutorId == request.auth.uid
        && incoming().fullName is string && incoming().fullName.size() > 0;
      allow update: if isSignedIn() && existing().tutorId == request.auth.uid
        && incoming().tutorId == existing().tutorId;
      allow delete: if isSignedIn() && existing().tutorId == request.auth.uid;

      // Sub-collections
      match /studyPlans/{planId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/students/$(studentId)).data.tutorId == request.auth.uid;
      }
      match /sessions/{sessionId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/students/$(studentId)).data.tutorId == request.auth.uid;
      }
      match /assignments/{assignmentId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/students/$(studentId)).data.tutorId == request.auth.uid;
      }
      match /tests/{testId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/students/$(studentId)).data.tutorId == request.auth.uid;
      }
      match /mistakes/{mistakeId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/students/$(studentId)).data.tutorId == request.auth.uid;
      }
    }
  }
}
